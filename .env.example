# ============================================================================
# VoiceSnip Configuration
# ============================================================================
# This file is named:
#   - .env on Linux
#   - voicesnip.ini on Windows
# The format is the same on both platforms.
#
# ============================================================================
# Deepgram Configuration (Cloud Provider)
# ============================================================================
# Only required if using Deepgram provider
# API Key must be configured here for security reasons
DEEPGRAM_API_KEY=your_api_key_here
DEEPGRAM_ENDPOINT=https://api.eu.deepgram.com/v1/listen #eu
# DEEPGRAM_ENDPOINT=https://api.deepgram.com/v1/listen #us

# ============================================================================
# STT Server - Model Selection (client selects model)
# ============================================================================
# Only required if using STT Server (Model Selection) provider
# Works with any OpenAI-compatible STT server (e.g. Speaches, whisper-asr-webservice)
# Change localhost to your server host if running remotely
STT_DYNAMIC_ENDPOINT=http://localhost:8000/v1/audio/transcriptions
STT_DYNAMIC_MODEL=Systran/faster-whisper-large-v3  # Default model (can be changed in GUI)
# STT_DYNAMIC_API_KEY=your_api_key_here  # Optional, only if your server requires authentication
# STT_DYNAMIC_VERIFY_SSL=false  # Set to false for self-signed certificates
# STT_DYNAMIC_ALLOWED_MODELS=Systran/faster-whisper-large-v3,Systran/faster-whisper-small  # Optional: restrict model dropdown

# ============================================================================
# STT Server - Fixed Model (model configured on server)
# ============================================================================
# Only required if using STT Server (Fixed Model) provider
# Works with any OpenAI-compatible STT server (e.g. faster-whisper-server, whisper-rocm)
# The model is configured on the server itself (no model selection in GUI)
STT_FIXED_ENDPOINT=http://localhost:8000/v1/audio/transcriptions
# STT_FIXED_API_KEY=your_api_key_here  # Optional, only if your server requires authentication
# STT_FIXED_VERIFY_SSL=false  # Set to false for self-signed certificates

# ============================================================================
# Settings Persistence
# ============================================================================
# All settings are automatically saved in config.json when you click "Start"
# in the GUI. The last used settings will be restored when you restart the
# application.
#
# Available Providers:
# - whisper-local-cpu: Local Whisper on CPU (Free, no API key needed)
# - whisper-local-gpu: Local Whisper on GPU (Free, requires NVIDIA CUDA)
# - whisper-local-rocm: Local Whisper on GPU (Free, requires AMD ROCm)
# - stt-server-fixed: STT Server - Fixed Model (model configured on server)
# - stt-server-dynamic: STT Server - Model Selection (model selectable in GUI)
# - deepgram-cloud: Deepgram Cloud API (requires API key below)
#
# Only API keys need to be configured in this .env file for security reasons.
# Everything else (Provider, Model, Language, Microphone, Hotkey) can be
# configured in the GUI!
