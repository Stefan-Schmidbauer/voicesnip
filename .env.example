# ============================================================================
# VoiceSnip Configuration
# ============================================================================
# This file is named:
#   - .env on Linux
#   - voicesnip.ini on Windows
# The format is the same on both platforms.
#
# ============================================================================
# Deepgram Configuration (Cloud Provider)
# ============================================================================
# Only required if using Deepgram provider
# API Key must be configured here for security reasons
DEEPGRAM_API_KEY=your_api_key_here
DEEPGRAM_ENDPOINT=https://api.eu.deepgram.com/v1/listen #eu
# DEEPGRAM_ENDPOINT=https://api.deepgram.com/v1/listen #us

# ============================================================================
# Speaches Server Configuration
# ============================================================================
# Only required if using Speaches server provider
# Change localhost to your server host if running remotely
SPEACHES_ENDPOINT=http://localhost:8000/v1/audio/transcriptions
SPEACHES_MODEL=Systran/faster-whisper-large-v3  # Default model (can be changed in GUI)
# SPEACHES_API_KEY=your_api_key_here  # Optional, only if your server requires authentication
# SPEACHES_VERIFY_SSL=false  # Set to false for self-signed certificates

# ============================================================================
# Settings Persistence
# ============================================================================
# All settings are automatically saved in config.json when you click "Start"
# in the GUI. The last used settings will be restored when you restart the
# application.
#
# Available Providers:
# - whisper-local-cpu: Local Whisper on CPU (Free, no API key needed)
# - whisper-local-gpu: Local Whisper on GPU (Free, requires CUDA)
# - speaches: Speaches server (depends on server setup)
# - deepgram-cloud: Deepgram Cloud API (requires API key below)
#
# Only API keys need to be configured in this .env file for security reasons.
# Everything else (Provider, Model, Language, Microphone, Hotkey) can be
# configured in the GUI!
